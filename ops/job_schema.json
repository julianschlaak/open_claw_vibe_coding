{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Bridge Job",
  "type": "object",
  "required": ["job_id", "type", "params", "created_at"],
  "properties": {
    "job_id": {"type": "string", "minLength": 1},
    "type": {
      "type": "string",
      "enum": ["run_mhm", "run_analysis", "commit_push", "healthcheck", "verify"]
    },
    "params": {"type": "object"},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
